generator client {
  provider = "prisma-client-js"
  // output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageFileEntityType {
  IMAGE
  VIDEO
  FILE
  AUDIO
}

enum MessageFileType {
  MP4
  OGG
  WEBM
  AVI
  IMAGE
  DOCUMENT
  MS_DOCUMENT
}

enum UserType {
  PRIVATE
  PUBLIC
}

enum UserRole {
  USER
  ADMIN
}

enum UserChatRole {
  ADMIN
  MODERATOR
  BOT
  MEMBER
  TECH_SUPPORT
}

enum ChatType {
  PUBLIC
  PRIVATE
}

enum MessageStatus {
  VIEWED
  UNREAD
  NOT_SENT
  DRAFT
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

enum UserChatStatus {
  ONLINE
  BUSY
  AT_WORK
  OFFLINE
}

model MessageFile {
  id           Int                   @id @default(autoincrement())
  fileName     String
  url          String
  optimizedUrl String
  type         MessageFileType
  description  String?
  entityType   MessageFileEntityType @default(FILE)

  messageId Int
  Message   Message[]
}

model User {
  id                  Int            @id @default(autoincrement())
  firstname           String
  surname             String
  username            String?        @unique
  birthDate           DateTime?
  password            String         @unique
  avatarUrl           String?
  avatarUrlOptimized  String?
  isHiddenContactInfo Boolean        @default(true)
  isAllowedToSearch   Boolean?       @default(true)
  country             String?
  city                String?
  email               String         @unique
  privateKey          String         @unique
  privateToken        String         @unique
  primaryPhone        String?        @unique
  type                UserType       @default(PRIVATE)
  role                UserRole       @default(USER)
  createdAt           DateTime?      @default(now())
  updatedAt           DateTime?      @default(now())
  chatStatus          UserChatStatus @default(OFFLINE)
  blockedUserIds      Int[]          @default([])

  chatParticipants ChatParticipant[]
}

model Message {
  id          Int           @id @default(autoincrement())
  content     String
  files       MessageFile[]
  status      MessageStatus @default(UNREAD)
  Chat        Chat[]
  createdAt   DateTime?     @default(now())
  updatedAt   DateTime?     @default(now())
  messageType MessageType   @default(TEXT)
  removed     Boolean       @default(false)
  hidden      Boolean       @default(false)

  childThreadId Int?
  chatId        Int
  senderId      Int
  threadId      Int?

  sender ChatParticipant @relation(fields: [senderId], references: [id])
  thread Thread?         @relation(fields: [threadId], references: [id])
}

model Thread {
  id           Int               @id @default(autoincrement())
  messages     Message[]
  participants ChatParticipant[]

  chatId          Int
  parentMessageId Int

  chat Chat @relation(fields: [chatId], references: [id])
}

model Chat {
  id                  Int       @id @default(autoincrement())
  avatarUrl           String?
  hidden              Boolean   @default(false)
  isActive            Boolean   @default(true)
  name                String
  readableName        String    @unique
  description         String?
  type                ChatType  @default(PUBLIC)
  isGroupChat         Boolean   @default(false)
  isSavedMessages     Boolean?  @default(false)
  createdAt           DateTime? @default(now())
  updatedAt           DateTime? @default(now())
  hasUnreadMessages   Boolean?  @default(false)
  empty               Boolean?  @default(true)
  unreadMessagesCount Int       @default(0)
  usersLimit          Int
  removed             Boolean   @default(false)
  encryptionSecret    String?   @default("Se9XNjAcmbrNoCooRPJq")

  lastMessageId Int?
  lastMessage   Message? @relation(fields: [lastMessageId], references: [id])

  Thread Thread[]
}

model ChatParticipant {
  id       Int          @id @default(autoincrement())
  chatRole UserChatRole @default(ADMIN)
  isMuted  Boolean?     @default(false)

  userId Int
  chatId Int

  messages Message[]
  threads  Thread[]
  user     User      @relation(fields: [userId], references: [id])
}

model ChatInvite {
  id                    Int          @id @default(autoincrement())
  fromChatParticipantId Int
  targetUserId          Int
  expirationDate        DateTime
  role                  UserChatRole
  token                 String       @unique
  chatId                Int
}

model ChatParticipantGatewayState {
  id       Int    @id @default(autoincrement())
  clientId String @unique
  userId   Int
}

model UserConfirmation {
  id        Int      @id @default(autoincrement())
  userId    Int
  email     String
  code      String
  createdAt DateTime @default(now())
  confirmed Boolean  @default(false)
}
